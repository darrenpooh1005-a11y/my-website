<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>LogicMath AI - 全裝置極致優化版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/3.2.2/es5/tex-mml-chtml.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&family=Outfit:wght@600;900&display=swap');
        
        :root {
            --primary: #06b6d4;
            --success: #10b981;
            --error: #ef4444;
            --bg: #020617;      
            --surface: #1e293b;
            --text: #ffffff;
            --card-bg: rgba(15, 23, 42, 0.95);
            --border: rgba(255, 255, 255, 0.15);
        }

        .light-theme {
            --bg: #f1f5f9;      
            --surface: #ffffff;
            --text: #0f172a;    
            --primary: #0891b2;
            --card-bg: #ffffff;
            --border: rgba(0, 0, 0, 0.1);
        }

        html, body { 
            overscroll-behavior-y: contain;
            height: 100%;
            background-color: var(--bg);
            color: var(--text);
            transition: background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1), color 0.4s ease;
            /* 針對行動端安全區域 */
            padding-top: env(safe-area-inset-top);
            padding-bottom: env(safe-area-inset-bottom);
            padding-left: env(safe-area-inset-left);
            padding-right: env(safe-area-inset-right);
        }

        body {
            font-family: 'Noto Sans TC', sans-serif;
            background-image: radial-gradient(circle at 1px 1px, var(--border) 1px, transparent 0);
            background-size: 32px 32px;
            -webkit-font-smoothing: antialiased;
            -webkit-tap-highlight-color: transparent;
        }

        /* 觸控強化按鈕 */
        .btn-logic {
            transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 0 rgba(0, 0, 0, 0.4);
            border: 2px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            user-select: none;
            touch-action: manipulation;
        }
        .light-theme .btn-logic {
            box-shadow: 0 4px 0 rgba(0, 0, 0, 0.15);
            border: 2px solid rgba(0, 0, 0, 0.05);
        }
        .btn-logic:active {
            transform: translateY(2px) scale(0.98);
            box-shadow: 0 1px 0 rgba(0, 0, 0, 0.4);
        }

        /* 高對比元素 */
        .active-pill {
            background-color: var(--primary) !important;
            color: white !important;
            box-shadow: 0 0 20px var(--primary);
            border: 2px solid rgba(255, 255, 255, 0.3) !important;
        }

        /* 瞄準框 - 行動端比例微調 */
        .target-box { position: relative; }
        .target-box::before, .target-box::after {
            content: ""; position: absolute; width: 20px; height: 20px;
            border-color: var(--primary); border-style: solid; opacity: 1; pointer-events: none;
            filter: drop-shadow(0 0 5px var(--primary));
        }
        @media (min-width: 768px) {
            .target-box::before, .target-box::after { width: 30px; height: 30px; }
        }
        .target-corner-tl { top: 8px; left: 8px; border-width: 5px 0 0 5px; border-top-left-radius: 12px; }
        .target-corner-tr { top: 8px; right: 8px; border-width: 5px 5px 0 0; border-top-right-radius: 12px; }
        .target-corner-bl { bottom: 8px; left: 8px; border-width: 0 0 5px 5px; border-bottom-left-radius: 12px; }
        .target-corner-br { bottom: 8px; right: 8px; border-width: 0 5px 5px 0; border-bottom-right-radius: 12px; }

        .guide-line {
            width: 90%; height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            opacity: 0.3; margin: 0 auto;
        }

        .hud-glass {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }

        .progress-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--surface); transition: all 0.2s ease; }
        @media (min-width: 768px) { .progress-dot { width: 12px; height: 12px; } }
        .progress-dot.active { background: var(--primary); transform: scale(1.4); box-shadow: 0 0 10px var(--primary); }

        .bungee { font-family: 'Outfit', sans-serif; font-weight: 900; }
        
        ::-webkit-scrollbar { width: 0px; }

        input, select, textarea {
            transition: all 0.2s ease;
            background: rgba(0, 0, 0, 0.25) !important;
            border: 2px solid var(--border) !important;
            color: var(--text) !important;
            font-size: 16px !important; /* 防止 iOS 自動縮放 */
        }
        .light-theme input, .light-theme select, .light-theme textarea {
            background: #f8fafc !important;
            border: 2px solid #e2e8f0 !important;
        }

        @keyframes door-portal {
            0%, 100% { box-shadow: 0 0 10px var(--primary); transform: scale(1); }
            50% { box-shadow: 0 0 25px var(--primary); transform: scale(1.03); }
        }
        .anywhere-door-active { animation: door-portal 2.5s infinite ease-in-out; cursor: pointer; border: 2px solid rgba(255,255,255,0.2) !important; }

        #toast {
            position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%) translateY(120px);
            background: var(--primary); color: #000; padding: 12px 28px; border-radius: 99px;
            font-size: 14px; font-weight: 900; transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 1000; box-shadow: 0 10px 20px rgba(0,0,0,0.4);
            white-space: nowrap;
        }
        #toast.show { transform: translateX(-50%) translateY(0); }

        /* 行動端導覽列優化 */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="flex flex-col">

    <div id="toast"></div>

    <!-- HUD - 行動端緊湊設計 -->
    <div class="fixed top-0 left-0 w-full z-50 p-3 md:p-4 pointer-events-none">
        <div class="container mx-auto max-w-4xl flex items-center gap-2 md:gap-3">
            <button id="exit-btn" onclick="quitToMenu()" class="hidden pointer-events-auto w-10 h-10 md:w-14 md:h-14 flex items-center justify-center rounded-2xl hud-glass text-red-500 btn-logic">✕</button>
            
            <div class="flex-1 hud-glass rounded-2xl md:rounded-[2.5rem] p-3 md:p-4 shadow-xl flex items-center gap-3 md:gap-6 px-4 md:px-8 pointer-events-auto">
                <div id="dots-container" class="flex gap-1.5 md:gap-3 flex-1 justify-center items-center overflow-hidden"></div>
                <div class="flex items-center gap-2 md:gap-3 border-l pl-3 md:pl-6 border-slate-500/30">
                    <span id="xp-display" class="text-lg md:text-2xl text-cyan-400 bungee">0</span>
                    <span class="text-[8px] md:text-[10px] font-black opacity-60 uppercase tracking-widest">XP</span>
                </div>
            </div>

            <button onclick="toggleMode('settings')" class="pointer-events-auto w-10 h-10 md:w-14 md:h-14 flex items-center justify-center rounded-2xl hud-glass text-cyan-400 btn-logic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-5 h-5 md:w-7 md:h-7"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
            </button>
        </div>
    </div>

    <!-- Header -->
    <header id="main-header" class="max-w-5xl mx-auto pt-24 md:pt-36 pb-12 px-6 text-center transition-all">
        <div class="flex flex-col items-center mb-10 md:mb-16">
            <div id="logo-icon" onclick="resetToGlobal()" class="w-20 h-20 md:w-28 md:h-28 bg-cyan-600 rounded-3xl shadow-2xl flex items-center justify-center mb-6 md:mb-10 anywhere-door-active transform transition-all active:scale-90 border-2 md:border-4 border-white/20">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-10 h-10 md:w-14 md:h-14"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </div>
            <h1 class="text-4xl md:text-6xl font-black bungee tracking-tighter mb-3">LogicMath AI</h1>
            <p id="user-welcome" class="text-cyan-500 font-black uppercase tracking-[0.2em] text-[10px] md:text-sm">載入個人化對焦空間...</p>
        </div>

        <!-- 行動端滾動導覽 -->
        <nav id="main-nav" class="flex md:grid md:grid-cols-5 gap-3 mb-12 overflow-x-auto no-scrollbar pb-4 -mx-6 px-6">
            <button onclick="toggleMode('library')" id="mode-library" class="whitespace-nowrap px-6 py-3 md:p-5 rounded-2xl font-black text-xs btn-logic bg-cyan-600 text-white shrink-0">📚 找單元</button>
            <button onclick="toggleMode('exam')" id="mode-exam" class="whitespace-nowrap px-6 py-3 md:p-5 rounded-2xl font-black text-xs btn-logic bg-slate-800 text-slate-400 shrink-0">🎯 考試</button>
            <button onclick="toggleMode('vocab')" id="mode-vocab" class="whitespace-nowrap px-6 py-3 md:p-5 rounded-2xl font-black text-xs btn-logic bg-slate-800 text-slate-400 shrink-0">📖 字典</button>
            <button onclick="toggleMode('homework')" id="mode-homework" class="whitespace-nowrap px-6 py-3 md:p-5 rounded-2xl font-black text-xs btn-logic bg-slate-800 text-slate-400 shrink-0">📝 助手</button>
            <button onclick="toggleMode('guide')" id="mode-guide" class="whitespace-nowrap px-6 py-3 md:p-5 rounded-2xl font-black text-xs btn-logic bg-slate-800 text-slate-400 shrink-0">❓ 說明</button>
        </nav>

        <div id="view-container" class="w-full">
            <div id="unit-view" class="space-y-8">
                <div id="tailor-banner" class="hidden bg-cyan-500/10 p-4 md:p-6 rounded-2xl border border-cyan-500/20 inline-block px-8 md:px-12 mx-auto">
                    <p class="text-cyan-400 font-bold text-sm md:text-lg flex items-center gap-3">
                        🚪 任意門鎖定中
                    </p>
                </div>

                <div id="filter-nav" class="flex justify-center gap-2 mb-8 flex-wrap">
                    <button onclick="filterData(null, this)" class="nav-btn active-pill px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-widest">全部</button>
                    <button onclick="filterData('elementary', this)" class="nav-btn px-5 py-2 rounded-full text-[10px] font-black bg-slate-800 text-slate-500">國小</button>
                    <button onclick="filterData('junior', this)" class="nav-btn px-5 py-2 rounded-full text-[10px] font-black bg-slate-800 text-slate-500">國中</button>
                    <button onclick="filterData('senior', this)" class="nav-btn px-5 py-2 rounded-full text-[10px] font-black bg-slate-800 text-slate-500">高中</button>
                    <button onclick="filterData('college', this)" class="nav-btn px-5 py-2 rounded-full text-[10px] font-black bg-slate-800 text-slate-500">大學</button>
                </div>

                <div id="unit-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-10"></div>
            </div>

            <!-- 設定視圖 -->
            <div id="settings-view" class="hidden max-w-xl mx-auto space-y-6">
                <div class="hud-glass p-8 md:p-12 rounded-3xl md:rounded-[3.5rem] text-left space-y-6 md:space-y-10">
                    <h3 class="text-2xl md:text-4xl font-black text-cyan-500 text-center">個人核心 ⚙️</h3>
                    <div class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black opacity-50 uppercase tracking-widest">我的暱稱</label>
                            <input type="text" id="setting-nickname" class="w-full p-5 rounded-2xl font-bold" placeholder="名字">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black opacity-50 uppercase tracking-widest">學習階段</label>
                            <select id="setting-stage" class="w-full p-5 rounded-2xl font-bold appearance-none">
                                <option value="null">自由探索</option>
                                <option value="elementary">臺灣 國小</option>
                                <option value="junior">臺灣 國中</option>
                                <option value="senior">臺灣 高中</option>
                                <option value="college">大學 基礎</option>
                            </select>
                        </div>
                        <div class="pt-6 flex items-center justify-between border-t border-slate-700">
                            <span class="font-bold text-sm">視覺模式</span>
                            <div class="flex gap-3">
                                <button onclick="setTheme('dark')" class="px-5 py-3 rounded-xl bg-slate-900 text-cyan-400 text-xs font-black border border-cyan-500">深夜</button>
                                <button onclick="setTheme('light')" class="px-5 py-3 rounded-xl bg-white text-slate-900 text-xs font-black border">簡約</button>
                            </div>
                        </div>
                    </div>
                    <button onclick="saveSettings()" class="w-full py-5 bg-cyan-600 text-white rounded-2xl font-black text-xl btn-logic">儲存</button>
                </div>
            </div>

            <!-- 字典、助手等略 (邏輯維持) -->
            <div id="vocab-view" class="hidden space-y-8"><input type="text" id="vocab-search" oninput="handleVocabSearch()" class="w-full max-w-md mx-auto block p-5 rounded-2xl font-bold text-lg" placeholder="搜尋術語..."><div id="vocab-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"></div></div>
            <div id="homework-view" class="hidden max-w-2xl mx-auto"><div class="hud-glass p-8 rounded-3xl"><textarea id="hw-input" class="w-full h-40 p-6 rounded-2xl mb-6 font-bold text-lg" placeholder="貼上難題..."></textarea><button onclick="solveHomework()" class="w-full py-5 bg-cyan-600 text-white rounded-2xl font-black text-2xl btn-logic">解析</button><div id="hw-result" class="hidden mt-8 space-y-4"></div></div></div>
            <div id="guide-view" class="hidden max-w-2xl mx-auto text-left"><div class="hud-glass p-8 md:p-12 rounded-3xl space-y-6"><h3 class="text-2xl font-black text-cyan-600">快速說明 🧭</h3><ul class="space-y-6 text-sm md:text-lg font-bold opacity-80"><li class="flex gap-4"><span>1</span>設定階段，讓首頁只顯示適合你的內容。</li><li class="flex gap-4"><span>2</span>點擊 Logo 任意門隨時可以回到全區。</li><li class="flex gap-4"><span>3</span>練習模式可以按提示獲取邏輯解析。</li></ul></div></div>
        </div>
    </header>

    <!-- 主作答區 - 行動端全屏對焦優化 -->
    <main id="main-content" class="w-full max-w-2xl px-4 md:px-6 pb-24 mx-auto flex-1 flex flex-col">
        <div id="practice-zone" class="hidden flex-1 flex flex-col space-y-4">
            <div id="problem-card" class="target-box hud-glass p-8 md:p-20 rounded-[3rem] md:rounded-[5rem] text-center relative flex-1 flex flex-col justify-center">
                <div class="target-corner-tl"></div><div class="target-corner-tr"></div><div class="target-corner-bl"></div><div class="target-corner-br"></div>
                <div id="q-label" class="text-[10px] font-black text-cyan-500 tracking-[0.4em] uppercase mb-4 opacity-70">Lock On</div>
                <div id="problem-text" class="text-4xl md:text-9xl font-black py-8 md:py-16 tracking-tighter min-h-[150px] md:min-h-[250px] flex items-center justify-center"></div>
                <div class="guide-line mb-8 md:mb-14"></div>
                
                <div class="space-y-6">
                    <!-- 針對行動端優化輸入 -->
                    <input type="text" id="user-answer" inputmode="decimal" class="w-full p-6 md:p-12 rounded-3xl md:rounded-[3.5rem] text-center text-4xl md:text-7xl font-black outline-none" placeholder="?" onkeypress="if(event.key==='Enter') checkAnswer()">
                    <div class="flex gap-3">
                        <button onclick="checkAnswer()" class="flex-[2] bg-cyan-600 text-white py-5 md:py-8 rounded-2xl md:rounded-[3.5rem] font-black text-xl md:text-4xl btn-logic">送出</button>
                        <button id="hint-btn" onclick="showStep()" class="flex-1 bg-slate-800 text-slate-400 py-5 md:py-8 rounded-2xl md:rounded-[3.5rem] font-bold text-xs btn-logic">提示</button>
                    </div>
                </div>
            </div>
            <div id="teaching-zone" class="hidden space-y-4 text-left"><div id="steps-list" class="space-y-3"></div><button id="next-btn" onclick="generateNext()" class="hidden w-full py-6 bg-emerald-600 text-white rounded-3xl font-black text-xl btn-logic">下一題 ➔</button></div>
        </div>

        <!-- 結算與檢討 -->
        <div id="result-zone" class="hidden text-center space-y-10 py-10"><div id="score-emoji" class="text-[8rem]">🎖️</div><div><h2 class="text-7xl md:text-9xl font-black bungee" id="final-score">100</h2><p class="text-cyan-400 font-bold mt-4 text-xl" id="final-comment">精準命中！</p></div><button onclick="quitToMenu()" class="block mx-auto py-5 px-16 bg-slate-800 text-white rounded-2xl font-black text-lg btn-logic">返回主頁</button></div>
        <div id="review-zone" class="hidden space-y-8"><div class="text-center font-black text-rose-500 text-xl uppercase tracking-widest">錯題精進</div><div class="hud-glass p-8 rounded-3xl text-center"><div id="review-problem-text" class="text-4xl font-black py-8"></div><div id="review-steps" class="space-y-3 mb-8 text-left"></div><input type="text" id="review-answer" inputmode="decimal" class="w-full p-6 rounded-2xl text-center text-3xl font-black outline-none" placeholder="輸入答案..."><button onclick="checkReviewAnswer()" class="w-full mt-6 py-6 bg-rose-600 text-white rounded-2xl font-black text-xl btn-logic">完成檢討</button></div></div>
    </main>

    <!-- 單元啟動彈窗 - 手機縮放優化 -->
    <div id="setup-zone" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-6 bg-slate-950/95 backdrop-blur-xl">
        <div class="hud-glass rounded-[3rem] md:rounded-[5rem] p-10 md:p-24 max-w-lg w-full shadow-2xl text-center border-none">
            <div id="setup-icon-container" class="w-20 h-20 md:w-28 md:h-28 bg-cyan-500/20 text-cyan-500 rounded-3xl flex items-center justify-center mx-auto mb-8"></div>
            <h3 class="text-3xl md:text-5xl font-black mb-3" id="selected-unit-name">單元</h3>
            <p id="selected-unit-desc" class="opacity-40 text-sm mb-10 tracking-wide">臺灣 108 課綱規範</p>
            <div class="space-y-4">
                <button onclick="startChallenge(false)" class="w-full p-5 md:p-8 bg-cyan-600 text-white rounded-2xl md:rounded-[2.5rem] font-black flex justify-between items-center btn-logic text-lg md:text-2xl">練習 ➔</button>
                <button onclick="startChallenge(true)" class="w-full p-5 md:p-8 bg-slate-800 text-slate-300 rounded-2xl md:rounded-[2.5rem] font-black flex justify-between items-center border border-slate-700 btn-logic text-lg md:text-2xl">考試 ➔</button>
                <button onclick="closeSetup()" class="w-full py-4 opacity-40 font-black text-xs mt-4">取消</button>
            </div>
        </div>
    </div>

    <script>
        const apiKey = ""; 
        const units = [
            { id: 'add_e', cat: 'elementary', name: '整數加減', icon: '<path d="M12 5v14M5 12h14"/>', desc: '國小：大數字進退位邏輯' },
            { id: 'mul_e', cat: 'elementary', name: '整數乘除', icon: '<path d="M18 6 6 18M6 6l12 12"/>', desc: '國小：乘法表與平分概念' },
            { id: 'neg_j', cat: 'junior', name: '負數與數線', icon: '<path d="M5 12h14"/>', desc: '國中：正負號運算' },
            { id: 'linear_j', cat: 'junior', name: '一次方程式', icon: '<path d="M4 19h16M4 5h16M12 5v14"/>', desc: '國中：解未知數 x' },
            { id: 'exp_s', cat: 'senior', name: '指數與對數', icon: '<path d="M3 3v18h18"/>', desc: '高中：log 與指數律' },
            { id: 'tri_s', cat: 'senior', name: '三角函數基礎', icon: '<path d="M3 21h18L12 3z"/>', desc: '高中：sin, cos 基礎' },
            { id: 'diff_c', cat: 'college', name: '基礎微積分', icon: '<path d="m13 10 4-4m-4 4 4 4"/>', desc: '大學：變化率微分' }
        ];

        const vocabulary = [
            { cat: 'elementary', en: 'Integer', zh: '整數', desc: '不含小數的數。' },
            { cat: 'junior', en: 'Variable', zh: '變數', desc: '代表未知數，如 x。' }
        ];

        let state = { 
            activeUnit: null, xp: 0, 
            nickname: '使用者', stage: null, theme: 'dark',
            currentAnswer: '', questionCount: 0, totalToComplete: 20,
            currentView: 'library', isExamMode: false,
            examScore: 0, wrongQuestions: [], reviewIndex: 0,
            currentFilter: null
        };
        let stepIndex = 0, problemSteps = [];

        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.innerText = msg; toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function setTheme(mode) {
            state.theme = mode;
            if (mode === 'light') {
                document.body.classList.add('light-theme');
                document.querySelectorAll('nav button').forEach(b => { if(!b.classList.contains('bg-cyan-500')) b.classList.replace('bg-slate-800', 'bg-white'); });
            } else {
                document.body.classList.remove('light-theme');
                document.querySelectorAll('nav button').forEach(b => { if(!b.classList.contains('bg-cyan-500')) b.classList.replace('bg-white', 'bg-slate-800'); });
            }
        }

        function toggleMode(mode) {
            state.currentView = mode;
            ['library', 'exam', 'vocab', 'homework', 'guide', 'settings'].forEach(m => {
                const btn = document.getElementById(`mode-${m}`);
                if (btn) {
                    if (m === mode) { btn.classList.add('bg-cyan-500', 'text-white'); btn.classList.remove('bg-slate-800', 'bg-white', 'text-slate-400', 'text-slate-500'); }
                    else { 
                        btn.classList.remove('bg-cyan-500', 'text-white'); 
                        btn.classList.add(state.theme === 'light' ? 'bg-white' : 'bg-slate-800'); 
                        btn.classList.add(state.theme === 'light' ? 'text-slate-500' : 'text-slate-400');
                    }
                }
            });
            document.getElementById('unit-view').style.display = (mode === 'library' || mode === 'exam') ? 'block' : 'none';
            document.getElementById('vocab-view').style.display = (mode === 'vocab') ? 'block' : 'none';
            document.getElementById('homework-view').style.display = (mode === 'homework') ? 'block' : 'none';
            document.getElementById('guide-view').style.display = (mode === 'guide') ? 'block' : 'none';
            document.getElementById('settings-view').style.display = (mode === 'settings') ? 'block' : 'none';
            if (mode === 'library' || mode === 'exam') renderLibrary(state.currentFilter);
        }

        function saveSettings() {
            state.nickname = document.getElementById('setting-nickname').value || '使用者';
            state.stage = document.getElementById('setting-stage').value === 'null' ? null : document.getElementById('setting-stage').value;
            document.getElementById('user-welcome').innerText = `你好，${state.nickname}！階段：${state.stage ? document.getElementById('setting-stage').options[document.getElementById('setting-stage').selectedIndex].text : '探索'}`;
            state.currentFilter = state.stage;
            document.getElementById('tailor-banner').classList.toggle('hidden', !state.stage);
            document.getElementById('filter-nav').classList.toggle('hidden', !!state.stage);
            toggleMode('library');
            showToast("個人核心已更新！");
        }

        function resetToGlobal() {
            state.stage = null; state.currentFilter = null;
            document.getElementById('tailor-banner').classList.add('hidden');
            document.getElementById('filter-nav').classList.remove('hidden');
            document.getElementById('setting-stage').value = 'null';
            filterData(null, document.querySelector('.nav-btn'));
            toggleMode('library');
            confetti({ particleCount: 50, spread: 60, origin: { y: 0.1 } });
            showToast("回到全區探索！");
        }

        function filterData(cat, btn) {
            state.currentFilter = cat;
            document.querySelectorAll('.nav-btn').forEach(b => {
                b.classList.remove('active-pill');
                b.classList.add(state.theme === 'light' ? 'bg-white' : 'bg-slate-800');
            });
            if (btn) btn.classList.add('active-pill');
            renderLibrary(cat);
        }

        function renderLibrary(cat) {
            const grid = document.getElementById('unit-grid'); grid.innerHTML = '';
            units.filter(u => !cat || u.cat === cat).forEach(u => {
                const card = document.createElement('div');
                card.className = "hud-glass p-8 md:p-10 rounded-3xl md:rounded-[3.5rem] hover:border-cyan-500/50 cursor-pointer active:scale-95 btn-logic transition-all group fade-section border-transparent border-2";
                card.onclick = () => openSetup(u);
                card.innerHTML = `
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-cyan-900/30 text-cyan-400 rounded-2xl flex items-center justify-center mb-6 md:mb-8 group-hover:rotate-12 transition-transform shadow-xl">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-6 h-6 md:w-8 md:h-8">${u.icon}</svg>
                    </div>
                    <h3 class="font-black text-xl md:text-2xl mb-4">${u.name}</h3>
                    <div class="flex gap-2"><span class="px-3 py-1 bg-cyan-900/50 text-cyan-400 rounded-lg text-[9px] font-black uppercase tracking-widest">${u.cat}</span></div>
                `;
                grid.appendChild(card);
            });
        }

        function openSetup(unit) {
            state.activeUnit = unit;
            document.getElementById('selected-unit-name').innerText = unit.name;
            document.getElementById('setup-icon-container').innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-10 h-10 md:w-14 md:h-14">${unit.icon}</svg>`;
            document.getElementById('setup-zone').classList.remove('hidden');
        }

        function closeSetup() { document.getElementById('setup-zone').classList.add('hidden'); }

        function startChallenge(examMode) {
            state.isExamMode = examMode;
            state.questionCount = 0; state.examScore = 0;
            closeSetup();
            document.body.classList.add('focus-mode');
            document.getElementById('main-header').classList.add('hidden');
            document.getElementById('practice-zone').classList.remove('hidden');
            document.getElementById('exit-btn').classList.remove('hidden');
            const dots = document.getElementById('dots-container'); dots.innerHTML = '';
            for(let i=0; i<20; i++) {
                const d = document.createElement('div'); d.className = 'progress-dot'; d.id = `dot-${i+1}`;
                dots.appendChild(d);
            }
            generateNext();
        }

        function generateNext() {
            if (state.questionCount >= state.totalToComplete) { showExamResult(); return; }
            state.questionCount++; stepIndex = 0;
            document.querySelectorAll('.progress-dot').forEach((d, i) => d.classList.toggle('active', i < state.questionCount));
            document.getElementById('q-label').innerText = `FLOW | ${state.questionCount} / 20`;
            document.getElementById('steps-list').innerHTML = '';
            document.getElementById('teaching-zone').classList.add('hidden');
            document.getElementById('next-btn').classList.add('hidden');
            document.getElementById('user-answer').value = '';
            const prob = buildProblem();
            problemSteps = prob.steps; state.currentAnswer = prob.answer;
            document.getElementById('problem-text').innerHTML = `\\[ ${prob.display} \\]`;
            MathJax.typeset();
            // 在行動端延遲 focus 以免 layout 閃爍
            setTimeout(() => document.getElementById('user-answer').focus(), 500);
        }

        function buildProblem() {
            const rand = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;
            let d = { display: '', answer: '', steps: [] };
            switch(state.activeUnit.id) {
                case 'add_e':
                    const a1 = rand(10, 99), a2 = rand(10, 99);
                    d.display = `${a1} + ${a2} = ?`; d.answer = (a1+a2).toString();
                    d.steps = [`我們先算個位數相加。`, `再算十位。`, `結果是 ${a1+a2}。` ];
                    break;
                case 'linear_j':
                    const x = rand(2, 9), k = rand(1, 10);
                    d.display = `x + ${k} = ${x+k}`; d.answer = x.toString();
                    d.steps = [`等量公理：兩邊同時減去 ${k}。`, `即可鎖定 x = ${x}。` ];
                    break;
                default: 
                    const m1 = rand(3, 9), m2 = rand(2, 6);
                    d.display = `${m1} \\times ${m2} = ?`; d.answer = (m1*m2).toString();
                    d.steps = [`這是 ${m2} 個 ${m1}。`, `結果為 ${m1*m2}。` ];
            }
            return d;
        }

        function checkAnswer() {
            const userIn = document.getElementById('user-answer').value.trim();
            if (userIn === state.currentAnswer) {
                if(state.isExamMode) state.examScore += 5;
                if(!state.isExamMode) confetti({ particleCount: 50, spread: 60, origin: { y: 0.8 } });
                if (state.isExamMode) generateNext();
                else {
                    document.getElementById('teaching-zone').classList.remove('hidden');
                    document.getElementById('next-btn').classList.remove('hidden');
                    while(stepIndex < problemSteps.length) showStep(false);
                }
            } else {
                if(state.isExamMode) {
                    state.wrongQuestions.push({ display: document.getElementById('problem-text').innerHTML, answer: state.currentAnswer, steps: [...problemSteps] });
                    generateNext();
                } else { showStep(true); }
            }
        }

        function showStep(isHint = true) {
            const list = document.getElementById('steps-list');
            document.getElementById('teaching-zone').classList.remove('hidden');
            if (stepIndex < problemSteps.length) {
                const div = document.createElement('div');
                div.className = "ai-step p-4 md:p-5 bg-slate-800/50 rounded-2xl border border-white/5 shadow-xl fade-section flex items-start gap-4";
                div.innerHTML = `<div class="w-8 h-8 bg-cyan-600 text-black rounded-xl flex items-center justify-center font-black text-xs shrink-0">助</div><span class="font-bold text-sm md:text-lg">${problemSteps[stepIndex]}</span>`;
                list.appendChild(div);
                stepIndex++; MathJax.typeset();
                if(isHint) { state.xp = Math.max(0, state.xp + 5); document.getElementById('xp-display').innerText = state.xp; }
            }
        }

        function showExamResult() {
            document.getElementById('practice-zone').classList.add('hidden');
            document.getElementById('result-zone').classList.remove('hidden');
            const score = state.isExamMode ? state.examScore : 100;
            document.getElementById('final-score').innerText = `${score}`;
            state.xp += score * 2; document.getElementById('xp-display').innerText = state.xp;
            confetti({ particleCount: 200, spread: 80 });
        }

        function quitToMenu() {
            document.body.classList.remove('focus-mode');
            document.getElementById('main-header').classList.remove('hidden');
            document.getElementById('practice-zone').classList.add('hidden');
            document.getElementById('exit-btn').classList.add('hidden');
            document.getElementById('result-zone').classList.add('hidden');
            toggleMode('library');
        }

        async function toggleFullScreen() {
            try {
                if (!document.fullscreenElement) {
                    if (document.documentElement.requestFullscreen) await document.documentElement.requestFullscreen();
                    else showToast("環境限制全螢幕。");
                } else {
                    if (document.exitFullscreen) await document.exitFullscreen();
                }
            } catch (err) {
                showToast("全螢幕受限。");
            }
        }

        window.onload = () => toggleMode('library');
    </script>
</body>
</html>
